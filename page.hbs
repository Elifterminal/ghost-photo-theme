{{!< default}}

{{#post}}
<article class="photo-post {{post_class}}">
    {{#match @page.show_title_and_feature_image}}
    {{#if feature_image}}
    <div class="photo-post-hero">
        <img src="{{feature_image}}" alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}" loading="eager">
        {{#if feature_image_caption}}
            <figcaption class="photo-visually-hidden">{{feature_image_caption}}</figcaption>
        {{/if}}
        <div class="photo-post-hero-content">
            <h1 class="photo-post-title">{{title}}</h1>
        </div>
    </div>
    {{else}}
    <header class="photo-post-header">
        <h1 class="photo-post-title">{{title}}</h1>
    </header>
    {{/if}}
    {{/match}}

    <div class="photo-post-content gh-content">
        {{content}}
    </div>
</article>
{{/post}}
